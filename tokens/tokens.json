{
  "$description": "Bounded Systems brand tokens. Source of truth. Edit here; regenerate tokens.css via build-tokens.mjs.",
  "color": {
    "forest": {
      "$type": "color",
      "$value": "#0C5A42",
      "$description": "Primary brand fill"
    },
    "forest-deep": {
      "$type": "color",
      "$value": "#073D2C",
      "$description": "Pressed / deep surfaces"
    },
    "paper": {
      "$type": "color",
      "$value": "#EDEAE1",
      "$description": "App background, warm"
    },
    "card": {
      "$type": "color",
      "$value": "{color.white}",
      "$description": "Card surface — aliases white"
    },
    "card-alt": {
      "$type": "color",
      "$value": "#F4F1EA",
      "$description": "Light avatar fill"
    },
    "ink": {
      "$type": "color",
      "$value": "#16221C",
      "$description": "Primary text"
    },
    "ink-soft": {
      "$type": "color",
      "$value": "#5C6B63",
      "$description": "Secondary text"
    },
    "ink-mono": {
      "$type": "color",
      "$value": "#6E7C73",
      "$description": "Mono label / slug text"
    },
    "line": {
      "$type": "color",
      "$value": "#E4E0D4",
      "$description": "Hairline borders"
    },
    "white": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Mark on forest"
    }
  },
  "font": {
    "display": {
      "$type": "fontFamily",
      "$value": [
        "Space Grotesk",
        "sans-serif"
      ],
      "$description": "Headings & UI"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": [
        "IBM Plex Mono",
        "monospace"
      ],
      "$description": "Labels, slugs, code"
    }
  },
  "size": {
    "text-h1": {
      "$type": "dimension",
      "$value": "46px"
    },
    "text-h2": {
      "$type": "dimension",
      "$value": "26px"
    },
    "text-title": {
      "$type": "dimension",
      "$value": "18px"
    },
    "text-body": {
      "$type": "dimension",
      "$value": "15px"
    },
    "text-label": {
      "$type": "dimension",
      "$value": "11px"
    }
  },
  "radius": {
    "radius-lg": {
      "$type": "dimension",
      "$value": "18px",
      "$description": "Cards, large surfaces"
    },
    "radius-md": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Inputs, small surfaces"
    }
  },
  "text": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h1}",
        "fontWeight": 600,
        "lineHeight": 1.02,
        "letterSpacing": "-0.025em"
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h2}",
        "fontWeight": 600,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      }
    },
    "title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-title}",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "-0.01em"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-body}",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0"
      }
    },
    "label": {
      "$type": "typography",
      "$description": "Slug / eyebrow: mono uppercase tracked label.",
      "$value": {
        "fontFamily": "{font.mono}",
        "fontSize": "{size.text-label}",
        "fontWeight": 500,
        "lineHeight": 1,
        "letterSpacing": "0.14em",
        "textTransform": "uppercase"
      }
    }
  }
}