{
  "$description": "Bounded Systems brand tokens. Source of truth. Edit here; regenerate tokens.css via build-tokens.mjs.",
  "color": {
    "forest": {
      "$type": "color",
      "$value": "#0C5A42",
      "$description": "Primary brand fill"
    },
    "forest-deep": {
      "$type": "color",
      "$value": "#073D2C",
      "$description": "Pressed / deep surfaces"
    },
    "paper": {
      "$type": "color",
      "$value": "#EDEAE1",
      "$description": "App background, warm"
    },
    "card": {
      "$type": "color",
      "$value": "{color.white}",
      "$description": "Card surface — aliases white"
    },
    "card-alt": {
      "$type": "color",
      "$value": "#F4F1EA",
      "$description": "Light avatar fill"
    },
    "ink": {
      "$type": "color",
      "$value": "#16221C",
      "$description": "Primary text"
    },
    "ink-soft": {
      "$type": "color",
      "$value": "#5C6B63",
      "$description": "Secondary text"
    },
    "ink-mono": {
      "$type": "color",
      "$value": "#5E6B62",
      "$description": "Mono label / slug text (darkened to meet WCAG AA 4.5:1 on paper)"
    },
    "line": {
      "$type": "color",
      "$value": "#E4E0D4",
      "$description": "Hairline borders"
    },
    "white": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Mark on forest"
    },
    "forest-tint": {
      "$type": "color",
      "$value": "#E2EBE6",
      "$description": "Forest wash — subtle tinted surface"
    },
    "forest-soft": {
      "$type": "color",
      "$value": "#D2E0D8",
      "$description": "Forest soft — fills/borders on tinted surfaces"
    },
    "clay": {
      "$type": "color",
      "$value": "#A6432F",
      "$description": "Clay — accent / negative (the 'no' in transaction demos)"
    },
    "clay-tint": {
      "$type": "color",
      "$value": "#F2DED8",
      "$description": "Clay wash — negative surface"
    },
    "amber": {
      "$type": "color",
      "$value": "#B5762A",
      "$description": "Amber — caution / highlight"
    },
    "amber-tint": {
      "$type": "color",
      "$value": "#F3E8D6",
      "$description": "Amber wash — caution surface"
    }
  },
  "font": {
    "display": {
      "$type": "fontFamily",
      "$value": [
        "Space Grotesk",
        "sans-serif"
      ],
      "$description": "Headings & UI"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": [
        "IBM Plex Mono",
        "monospace"
      ],
      "$description": "Labels, slugs, code"
    }
  },
  "size": {
    "text-h1": {
      "$type": "dimension",
      "$value": "46px"
    },
    "text-h2": {
      "$type": "dimension",
      "$value": "26px"
    },
    "text-title": {
      "$type": "dimension",
      "$value": "18px"
    },
    "text-body": {
      "$type": "dimension",
      "$value": "15px"
    },
    "text-label": {
      "$type": "dimension",
      "$value": "11px"
    }
  },
  "radius": {
    "radius-lg": {
      "$type": "dimension",
      "$value": "18px",
      "$description": "Cards, large surfaces"
    },
    "radius-md": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Inputs, small surfaces"
    }
  },
  "grade": {
    "$description": "Graded-claim status colours. Base only — build-tokens.mjs derives -bg (light surface) and -fg (readable text) tints deterministically.",
    "enforced": {
      "$type": "color",
      "$value": "#3FB984",
      "$description": "Proven/enforced in running code"
    },
    "partial": {
      "$type": "color",
      "$value": "#C8902F",
      "$description": "Partially enforced"
    },
    "aspirational": {
      "$type": "color",
      "$value": "#7E8C83",
      "$description": "Aspirational / not yet enforced"
    }
  },
  "text": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h1}",
        "fontWeight": 600,
        "lineHeight": 1.02,
        "letterSpacing": "-0.025em"
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h2}",
        "fontWeight": 600,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      }
    },
    "title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-title}",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "-0.01em"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-body}",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0"
      }
    },
    "label": {
      "$type": "typography",
      "$description": "Slug / eyebrow: mono uppercase tracked label.",
      "$value": {
        "fontFamily": "{font.mono}",
        "fontSize": "{size.text-label}",
        "fontWeight": 500,
        "lineHeight": 1,
        "letterSpacing": "0.14em",
        "textTransform": "uppercase"
      }
    }
  }
}