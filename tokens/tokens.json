{
  "$description": "Bounded Systems brand tokens. Source of truth. Three tiers: primitive (raw palette) → color (semantic roles, alias primitives) → text (component recipes). Edit here; regenerate tokens.css via build-tokens.mjs. Only the semantic/recipe layers are emitted as --bs-*; primitives are the source-of-truth palette the semantics point at (change a primitive → every role that aliases it updates).",
  "primitive": {
    "$description": "Raw palette. Not emitted directly — referenced by the semantic color tier. Theming = change a primitive once.",
    "green-700": { "$type": "color", "$value": "#0C5A42", "$description": "Brand green" },
    "green-900": { "$type": "color", "$value": "#073D2C", "$description": "Deep green" },
    "green-100": { "$type": "color", "$value": "#E2EBE6", "$description": "Green wash" },
    "green-200": { "$type": "color", "$value": "#D2E0D8", "$description": "Green soft" },
    "green-300": { "$type": "color", "$value": "#BBD1CA", "$description": "Muted mint — text on forest (AA, 5.1:1)" },
    "green-500": { "$type": "color", "$value": "#58B196", "$description": "Bright sage — hairline/border on forest (non-text AA, 3.19:1; CVD-safe)" },
    "green-600": { "$type": "color", "$value": "#5F8971", "$description": "Deep sage — functional border/divider on LIGHT surfaces (non-text AA ≥3:1 on white/paper/tint; CVD-safe)" },
    "paper": { "$type": "color", "$value": "#EDEAE1", "$description": "Warm paper" },
    "white": { "$type": "color", "$value": "#FFFFFF" },
    "cream": { "$type": "color", "$value": "#F4F1EA", "$description": "Warm off-white" },
    "ink-900": { "$type": "color", "$value": "#16221C", "$description": "Near-black ink" },
    "ink-600": { "$type": "color", "$value": "#5C6B63", "$description": "Muted ink" },
    "ink-500": { "$type": "color", "$value": "#5E6B62", "$description": "Mono-label ink (WCAG-AA on paper)" },
    "line": { "$type": "color", "$value": "#888374", "$description": "Hairline / divider — warm grey, non-text AA ≥3:1 on white/paper/cream (CVD-safe)" },
    "clay-600": { "$type": "color", "$value": "#9F3E2B", "$description": "Clay — text AA + CVD-safe (≥4.5:1 under deuteranopia/protanopia/tritanopia on paper & clay wash)" },
    "clay-100": { "$type": "color", "$value": "#F2DED8", "$description": "Clay wash" },
    "amber-600": { "$type": "color", "$value": "#8C5818", "$description": "Amber — text AA + CVD-safe (≥4.5:1 under deuteranopia/protanopia/tritanopia on paper & amber wash)" },
    "amber-100": { "$type": "color", "$value": "#F3E8D6", "$description": "Amber wash" }
  },
  "color": {
    "forest": { "$type": "color", "$value": "{primitive.green-700}", "$description": "Primary brand fill" },
    "forest-deep": { "$type": "color", "$value": "{primitive.green-900}", "$description": "Pressed / deep surfaces" },
    "paper": { "$type": "color", "$value": "{primitive.paper}", "$description": "App background, warm" },
    "card": { "$type": "color", "$value": "{primitive.white}", "$description": "Card surface" },
    "card-alt": { "$type": "color", "$value": "{primitive.cream}", "$description": "Light avatar fill" },
    "ink": { "$type": "color", "$value": "{primitive.ink-900}", "$description": "Primary text" },
    "ink-soft": { "$type": "color", "$value": "{primitive.ink-600}", "$description": "Secondary text" },
    "ink-mono": { "$type": "color", "$value": "{primitive.ink-500}", "$description": "Mono label / slug text" },
    "line": { "$type": "color", "$value": "{primitive.line}", "$description": "Hairline borders" },
    "white": { "$type": "color", "$value": "{primitive.white}", "$description": "Mark on forest" },
    "forest-tint": { "$type": "color", "$value": "{primitive.green-100}", "$description": "Subtle tinted surface" },
    "forest-soft": { "$type": "color", "$value": "{primitive.green-600}", "$description": "Functional border/divider on light surfaces (non-text AA ≥3:1; was green-200 — split out so on-forest text can stay light while borders meet 1.4.11)" },
    "on-forest": { "$type": "color", "$value": "{primitive.green-200}", "$description": "Primary text on the forest panel (AA, 6.0:1)" },
    "on-forest-soft": { "$type": "color", "$value": "{primitive.green-300}", "$description": "Muted text / eyebrow on forest (AA, 5.1:1)" },
    "on-forest-line": { "$type": "color", "$value": "{primitive.green-500}", "$description": "Hairline / border on forest — functional non-text contrast (AA ≥3:1, CVD-safe)" },
    "clay": { "$type": "color", "$value": "{primitive.clay-600}", "$description": "Accent / negative" },
    "clay-tint": { "$type": "color", "$value": "{primitive.clay-100}", "$description": "Negative surface" },
    "amber": { "$type": "color", "$value": "{primitive.amber-600}", "$description": "Caution / highlight" },
    "amber-tint": { "$type": "color", "$value": "{primitive.amber-100}", "$description": "Caution surface" }
  },
  "font": {
    "display": {
      "$type": "fontFamily",
      "$value": [
        "Space Grotesk",
        "sans-serif"
      ],
      "$description": "Headings & UI"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": [
        "IBM Plex Mono",
        "monospace"
      ],
      "$description": "Labels, slugs, code"
    }
  },
  "size": {
    "text-h1": {
      "$type": "dimension",
      "$value": "46px"
    },
    "text-h2": {
      "$type": "dimension",
      "$value": "26px"
    },
    "text-title": {
      "$type": "dimension",
      "$value": "18px"
    },
    "text-body": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Body — 16px so primary body text clears the APCA size-aware comfort tier (Lc ≥90 at 16px) on paper/card, not just WCAG-2 AA. Was 15px (sub-16 → APCA floor Lc 100, unreachable)."
    },
    "text-label": {
      "$type": "dimension",
      "$value": "11px"
    }
  },
  "radius": {
    "radius-lg": {
      "$type": "dimension",
      "$value": "18px",
      "$description": "Cards, large surfaces"
    },
    "radius-md": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Inputs, small surfaces"
    }
  },
  "control": {
    "$description": "Interactive-target / control sizing. The accessible-pointer-target tokens a surface uses for buttons, icon hit-areas, inputs, and list rows. min-tap-target is the WCAG 2.2 SC 2.5.8 (AA) floor (24px); control-md+ also meet SC 2.5.5 (AAA, 44px). Use a control-* token (or min-tap-target as a min-block/inline-size) so every interactive target ships an accessible bounding box — verified by the target-size member of the Token Accessibility suite.",
    "min-tap-target": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "WCAG 2.2 SC 2.5.8 (AA) minimum pointer-target side — the floor. Apply as min-width/min-height on any interactive control."
    },
    "sm": {
      "$type": "dimension",
      "$value": "36px",
      "$description": "Compact control (chips, dense toolbars) — clears 2.5.8 AA (24px) with margin."
    },
    "md": {
      "$type": "dimension",
      "$value": "44px",
      "$description": "Default control — meets 2.5.5 (AAA, 44px) and Apple HIG / Material touch-target guidance."
    },
    "lg": {
      "$type": "dimension",
      "$value": "52px",
      "$description": "Prominent / primary control."
    }
  },
  "grade": {
    "$description": "Graded-claim status colours. Base only — build-tokens.mjs derives -bg (light surface) and -fg (readable text) tints deterministically.",
    "enforced": {
      "$type": "color",
      "$value": "#3FB984",
      "$description": "Proven/enforced in running code"
    },
    "partial": {
      "$type": "color",
      "$value": "#C8902F",
      "$description": "Partially enforced"
    },
    "aspirational": {
      "$type": "color",
      "$value": "#7E8C83",
      "$description": "Aspirational / not yet enforced"
    }
  },
  "text": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h1}",
        "fontWeight": 600,
        "lineHeight": 1.02,
        "letterSpacing": "-0.025em"
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-h2}",
        "fontWeight": 600,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      }
    },
    "title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-title}",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "-0.01em"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.display}",
        "fontSize": "{size.text-body}",
        "fontWeight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0"
      }
    },
    "label": {
      "$type": "typography",
      "$description": "Slug / eyebrow: mono uppercase tracked label.",
      "$value": {
        "fontFamily": "{font.mono}",
        "fontSize": "{size.text-label}",
        "fontWeight": 500,
        "lineHeight": 1,
        "letterSpacing": "0.14em",
        "textTransform": "uppercase"
      }
    }
  }
}
