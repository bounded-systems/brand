{
  "name": "@bounded-systems/brand",
  "version": "1.3.0",
  "description": "Design system for Bounded Systems — tokens/CSS (MIT) plus brand identity artwork (proprietary, all rights reserved, see LICENSE).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://bounded.tools",
  "repository": { "type": "git", "url": "git+https://github.com/bounded-systems/brand.git" },
  "bugs": { "url": "https://github.com/bounded-systems/brand/issues" },
  "keywords": ["design-tokens", "brand", "css", "fonts", "bounded-systems"],
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public", "provenance": true },
  "files": [
    "css/",
    "tokens/tokens.css",
    "tokens/tokens.json",
    "tokens/tokens.ts",
    "tokens/manifest.schema.json",
    "content/strings.json",
    "mark/",
    "avatar/",
    "lockup/",
    "favicon-32.png",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./tokens/tokens.json",
    "./tokens.json": "./tokens/tokens.json",
    "./tokens.ts": "./tokens/tokens.ts",
    "./tokens.css": "./tokens/tokens.css",
    "./css/base.css": "./css/base.css",
    "./css/fonts.css": "./css/fonts.css",
    "./content/strings.json": "./content/strings.json",
    "./mark/*": "./mark/*",
    "./avatar/*": "./avatar/*",
    "./lockup/*": "./lockup/*",
    "./favicon-32.png": "./favicon-32.png",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepack": "npm run build:css && npm run build:ts",
    "build:css": "node tokens/build-tokens.mjs",
    "build:ts": "node tools/build-tokens-ts.mjs",
    "build:headers": "node tools/generate-headers.mjs",
    "check": "node tokens/build-tokens.mjs --check",
    "check:headers": "node tools/generate-headers.mjs --check dist/github-headers",
    "build:sd": "style-dictionary build --config style-dictionary.config.mjs",
    "tokens:ts": "node tools/build-tokens-ts.mjs",
    "tokens:ts:check": "node tools/build-tokens-ts.mjs --check",
    "tokens:dist": "node tools/build-tokens-dist.mjs",
    "tokens:dist:check": "node tools/build-tokens-dist.mjs --check",
    "verify:versions": "node tools/verify-versions.mjs",
    "build": "npm run build:css && npm run build:sd && npm run build:headers",
    "coverage": "node tools/coverage.mjs css design",
    "coverage:check": "node tools/coverage.mjs --check css",
    "coverage:colors": "node tools/coverage.mjs --colors --check css",
    "content": "node tools/content.mjs",
    "content:check": "node tools/content.mjs --check",
    "resume:build": "node tools/build-resume.mjs",
    "resume:pdf": "node tools/render-resume.mjs",
    "resume:check": "node tools/build-resume.mjs --check && node tools/resume-check.mjs --check",
    "meta": "node tools/meta.mjs",
    "a11y": "node tools/a11y.mjs",
    "a11y:check": "node tools/a11y.mjs --check",
    "palette": "node tools/palette.mjs",
    "palette:check": "npm run build:css && node tools/palette.mjs",
    "palette:verify": "node tools/palette.mjs --verify",
    "token-a11y": "node tools/token-a11y.mjs",
    "token-a11y:check": "npm run build:css && node tools/token-a11y.mjs",
    "token-a11y:verify": "node tools/token-a11y.mjs --verify"
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0"
  }
}
